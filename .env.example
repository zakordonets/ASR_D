# Hugging Face token for pyannote diarization models.
# Required if diarization is enabled.
HF_TOKEN=

# DeepSeek API key for normalization when NORMALIZATION_PROVIDER=deepseek
# Optional if you use OpenRouter instead.
DEEPSEEK_API_KEY=

# Generic OpenAI-compatible credentials.
# Normally leave empty unless you want to use another OpenAI-compatible backend.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Default normalization provider.
# Supported values right now: deepseek, openrouter
# CLI flag --llm overrides this value.
NORMALIZATION_PROVIDER=deepseek

# OpenRouter credentials for normalization when NORMALIZATION_PROVIDER=openrouter
OPENROUTER_API_KEY=
# OpenRouter OpenAI-compatible base URL.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default OpenRouter model id used for normalization.
OPENROUTER_MODEL=xiaomi/mimo-v2-flash
# Optional attribution header recommended by OpenRouter.
OPENROUTER_HTTP_REFERER=
# Optional app name header recommended by OpenRouter.
OPENROUTER_APP_NAME=asr-cli
# Enables/disables reasoning for OpenRouter models that support it.
# Usually false for transcript normalization to reduce cost and latency.
OPENROUTER_REASONING_ENABLED=false
